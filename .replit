modules = ["rust-stable", "nodejs-20", "bash", "postgresql-16"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[userenv]

[userenv.shared]
BUZZ_AUTO_MIGRATE = "true"
BUZZ_BIND_ADDR = "0.0.0.0:3000"
BUZZ_GIT_CONFORMANCE_PROBE = "false"
BUZZ_MEDIA_BASE_URL = "https://1c0b1ec3-3745-44bf-80d6-1143b67e10f0-00-1neui5hpbvv8a-mkvc5y5b.janeway.replit.dev/media"
BUZZ_REQUIRE_RELAY_MEMBERSHIP = "true"
BUZZ_SERVE_GIT_WEB_GUI = "true"
BUZZ_ADMIN_WEB_DIR = "/home/runner/workspace/admin-web/dist"
BUZZ_WEB_DIR = "/home/runner/workspace/web/dist"
REDIS_URL = "redis://127.0.0.1:6379"
RELAY_URL = "wss://1c0b1ec3-3745-44bf-80d6-1143b67e10f0-00-1neui5hpbvv8a-mkvc5y5b.janeway.replit.dev"
RELAY_OWNER_PUBKEY = "b67348f092c3821745acc619a353cc8d7ed16401d422e41204a78500ee04a2f7"
RUST_LOG = "buzz_relay=info,buzz_db=info,tower_http=warn"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Buzz Relay"

[[workflows.workflow]]
name = "Buzz Relay"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-replit.sh"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 9102
externalPort = 3000
