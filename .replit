modules = ["rust-stable", "nodejs-20", "bash", "python-base-3.13", "postgresql-16"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[userenv]

[userenv.shared]
BUZZ_AUTO_MIGRATE = "false"
BUZZ_BIND_ADDR = "0.0.0.0:5000"
BUZZ_GIT_CONFORMANCE_PROBE = "false"
BUZZ_REQUIRE_AUTH_TOKEN = "true"
BUZZ_REQUIRE_RELAY_MEMBERSHIP = "true"
BUZZ_SERVE_GIT_WEB_GUI = "true"
REDIS_URL = "redis://127.0.0.1:6379"
RELAY_OWNER_PUBKEY = "b67348f092c3821745acc619a353cc8d7ed16401d422e41204a78500ee04a2f7"
RUST_LOG = "buzz_relay=info,buzz_db=info,tower_http=warn"

[userenv.production]
BUZZ_CUSTOM_DOMAINS = "buzz.shopstrmarkets.com"

[deployment]
deploymentTarget = "vm"
run = ["bash", "scripts/start-replit.sh"]
build = ["bash", "scripts/prepare-deploy.sh"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Buzz Relay"

[[workflows.workflow]]
name = "Buzz Relay"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-replit.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 9102
externalPort = 3000
